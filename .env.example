# Copy to .env for local use, or add these in Vercel:
# Project Settings -> Environment Variables

# ---------------------------------------------------------------------------
# API server (local development)
# ---------------------------------------------------------------------------

# Port for `python main.py` or uvicorn (default: 10000)
PORT=10000

# ---------------------------------------------------------------------------
# Archive processing limits (recommended on Vercel)
# ---------------------------------------------------------------------------

# Max archive download size in bytes.
# Vercel /tmp is ~512 MB; default in code is 450 MB if unset on serverless.
# Example: 450 MB
AI_QR_MAX_ARCHIVE_BYTES=471859200

# Optional override for temp directory (usually not needed locally).
# On Vercel the app uses /tmp automatically.
# TMPDIR=/tmp

# ---------------------------------------------------------------------------
# CLI only (api/qr_from_storage_archive.py)
# Not required for the FastAPI /run endpoint.
# ---------------------------------------------------------------------------

# Direct archive or .ai file URL when running the script from command line
# AI_QR_URL=https://example.com/path/to/file.rar

# Same URL, base64-encoded (used when shell escaping is a problem)
# AI_QR_URL_B64=

# ---------------------------------------------------------------------------
# Set automatically by Vercel — do not set manually
# ---------------------------------------------------------------------------

# VERCEL=1

